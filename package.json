{
  "name": "seedr-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "AI tools configuration seeder",
  "scripts": {
    "prepare": "husky",
    "check-descriptions": "bash scripts/check-descriptions.sh",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "compile": "tsx scripts/compile-manifest.ts",
    "sync": "GITHUB_TOKEN=${GITHUB_TOKEN:-$(gh auth token 2>/dev/null)} tsx scripts/sync.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "eslint": "^10.0.0",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-react-refresh": "^0.5.0",
    "eslint-plugin-sonarjs": "^4.0.0",
    "eslint-plugin-unicorn": "^63.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "tsx": "^4.19.0",
    "turbo": "^2.9.14",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.1"
  },
  "lint-staged": {
    "apps/web/src/**/*.{ts,tsx}": "eslint"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "rollup": ">=4.59.0",
      "minimatch": ">=10.2.3",
      "@isaacs/brace-expansion@<=5.0.0": ">=5.0.1",
      "ajv@<6.14.0": ">=6.14.0",
      "esbuild@<0.28.1": ">=0.28.1",
      "postcss@<8.5.10": ">=8.5.10",
      "flatted@<3.4.2": ">=3.4.2",
      "picomatch@>=2.0.0 <2.3.2": "2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "4.0.4",
      "brace-expansion@>=5.0.0 <5.0.6": ">=5.0.6",
      "yaml@<2.8.3": ">=2.8.3"
    },
    "peerDependencyRules": {
      "allowAny": [
        "eslint"
      ]
    }
  }
}
