{
  "slug": "telegram",
  "name": "Telegram",
  "type": "plugin",
  "description": "Telegram channel for Claude Code — messaging bridge with built-in access control. Manage pairing, allowlists, and policy via /telegram:access.",
  "longDescription": "Ships **1 MCP server** and **2 skills** (`/telegram:configure`, `/telegram:access`). The MCP server provides tools for `reply` (text + attachments up to 50MB), `react` (Telegram-approved emoji), and `edit_message`. Photos are auto-downloaded to a local directory. Access control uses a 6-character pairing code tied to Telegram numeric user IDs, with support for DMs, group chats, and mention detection via `access.json`. Runs on Bun; shows typing indicators while Claude processes. Note: Telegram's Bot API has no message history or search — the bot only processes incoming messages.",
  "compatibility": [
    "claude"
  ],
