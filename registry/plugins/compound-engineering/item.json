{
  "slug": "compound-engineering",
  "name": "Compound Engineering",
  "type": "plugin",
  "description": "AI-powered development tools for code review, research, design, and workflow automation.",
  "longDescription": "Ships **29 agents**, **22 commands**, **19 skills**, and a `context7` MCP server.\n\n- **Code reviewers** (15): Rails, TypeScript, Python, security, performance, architecture, data integrity\n- **Research agents** (5): best practices, framework docs, git history\n- **Design agents** (3): Figma sync, iteration\n- **Workflow agents** (5): bug reproduction, PR resolution, linting\n- **Commands**: `/workflows:` suite (`plan`, `review`, `work`, `compound`, `brainstorm`)\n- **Skills**: browser automation, git worktree, image generation, swarm orchestration",
  "compatibility": [
    "claude"
  ],
  "pluginType": "package",
  "package": {
    "skill": 41,
    "agent": 6,
    "mcp": 1
  },
